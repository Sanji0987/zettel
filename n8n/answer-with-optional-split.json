        "id": "d16a36af-66e0-4664-bdb3-e9f7a83cecba",
        "name": "L2 Decompose Model",
        "type": "@n8n/n8n-nodes-langchain.lmChatGroq",
        "typeVersion": 1,
        "position": [
          672,
          560
        ],
        "credentials": {
          "groqApi": {
            "id": "woCh9CG7qUGXmSCX",
            "name": "Groq account"
          }
        }
      },
      {
        "parameters": {
          "jsCode": "let raw = ($input.first().json.output || '').toString();\nraw = raw.replace(/<think>[\\s\\S]*?<\\/think>/gi, '').replace(/<\\|think\\|>[\\s\\S]*?<\\|\\/?think\\|>/gi, '').replace(/```(?:json)?/gi, '').trim();\nlet arr = [];\nconst m = raw.match(/\\[[\\s\\S]*\\]/);\nif (m) { try { const p = JSON.parse(m[0]); if (Array.isArray(p)) arr = p; } catch (e) {} }\narr = arr.map(x => (x == null ? '' : x.toString().trim())).filter(Boolean);\nconst seen = new Set(); const out = [];\nfor (const s of arr) { const k = s.toLowerCase(); if (!seen.has(k)) { seen.add(k); out.push(s); } }\nconst capped = out.slice(0, 5);\nif (capped.length === 0) { return [{ json: { query: ($('L2 Gate').item.json.query) || '' } }]; }\nreturn capped.map(s => ({ json: { query: s } }));"
        },
        "id": "5b657083-b516-4659-96d7-6ffc87c65dd1",
        "name": "Parse L2",
        "type": "n8n-nodes-base.code",
        "typeVersion": 2,
        "position": [
          1024,
          608
        ]
      },
      {
        "parameters": {
          "jsCode": "const runs = $input.all();\nlet parts = [], sources = [];\nfor (const r of runs) { const a = (r.json.answer || '').toString(); if (a) parts.push(a); const s = r.json.sources || []; if (Array.isArray(s)) sources.push(...s); }\nreturn [{ json: { answer: parts.join('\\n\\n'), sources } }];"
        },
