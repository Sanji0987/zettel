      {
        "parameters": {
          "jsCode": "const j = $input.first().json;\nconst q = (j.query || '').toString();\nlet th = parseInt(j.threshold, 10); if (!th) th = 40;\nconst t = q.trim();\nconst wc = t ? t.split(/\\s+/).length : 0;\nconst pathB = wc > th ? 'split' : 'direct';\nreturn [{ json: { query: q, threshold: th, wordCount: wc, pathB } }];"
        },
