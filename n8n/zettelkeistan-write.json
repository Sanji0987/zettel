        "webhookId": "5caf45db-e483-4ef7-bb2e-262e8806b33c"
      },
      {
        "parameters": {
          "jsCode": "const item = $input.first().json;\nconst b = item.body || item;\nconst op = b.op === 'refine' ? 'refine' : 'draft';\nconst history = Array.isArray(b.history) ? b.history : [];\nconst historyText = history.map(h => (h.role === 'assistant' ? 'Assistant: ' : 'User: ') + (h.content||'')).join('\\n');\nconst cd = b.current_draft || {};\nconst cdTags = Array.isArray(cd.tags) ? cd.tags : [];\nconst draftText = 'Title: ' + (cd.title||'') + '\\nTags: ' + cdTags.join(', ') + '\\n\\n' + (cd.text||'');\nconst rh = Array.isArray(b.refine_history) ? b.refine_history : [];\nconst refineText = rh.map(h => (h.role === 'assistant' ? 'Assistant: ' : 'User: ') + (h.content||'')).join('\\n');\nconst feedback = (b.feedback||'').toString();\nconst draftId = (b.draft_id||'').toString();\nreturn [{ json: { op, historyText, draftText, refineText, feedback, draftId, cdTitle:(cd.title||'').toString(), cdText:(cd.text||'').toString(), cdTags } }];"
        },
        "id": "ae3b2ffe-8a4d-4c75-8dfb-d0c47f304023",
        "name": "Normalize",
