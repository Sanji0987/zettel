        },
        "id": "41aedc6d-d499-402a-8224-acab881e3726",
        "name": "Refine Model",
        "type": "@n8n/n8n-nodes-langchain.lmChatGroq",
        "typeVersion": 1,
        "position": [
          680,
          640
        ],
        "credentials": {
          "groqApi": {
            "id": "woCh9CG7qUGXmSCX",
            "name": "Groq account"
          }
        }
      },
      {
        "parameters": {
          "jsCode": "let raw = ($input.first().json.output || '').toString();\nraw = raw.replace(/<think>[\\s\\S]*?<\\/think>/gi,'').replace(/<\\|think\\|>[\\s\\S]*?<\\|\\/?think\\|>/gi,'').replace(/<\\|?\\/?think\\|?>/gi,'').replace(/```(?:json)?/gi,'').trim();\nlet o = {};\ntry { const m = raw.match(/\\{[\\s\\S]*\\}/); if (m) o = JSON.parse(m[0]); } catch(e) {}\nconst norm = $('Normalize').first().json;\nconst draft_id = (norm.draftId || '').toString();\nif (o.question && !o.title && !o.text) {\n  // Clarification: keep the current draft unchanged, just surface the question.\n  return [{ json: { draft_id, question: o.question.toString(), title: norm.cdTitle||'', text: norm.cdText||'', tags: norm.cdTags||[] } }];\n}\nconst title = (o.title || '').toString().slice(0,500);\nconst text = (o.text || '').toString();\nlet tags = Array.isArray(o.tags) ? o.tags : (typeof o.tags === 'string' ? o.tags.split(',') : []);\ntags = tags.map(t => t.toString().trim().toLowerCase()).filter(Boolean).slice(0,8);\nreturn [{ json: { draft_id, question: null, title, text, tags } }];"
        },
