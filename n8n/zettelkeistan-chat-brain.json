      {
        "parameters": {
          "jsCode": "const item = $input.first().json;\nconst message = (item.message || '').toString();\nlet threshold = 40;\ntry { const e = $env.DECOMP_WORD_THRESHOLD; if (e) threshold = parseInt(e, 10) || 40; } catch (x) {}\nconst trimmed = message.trim();\nconst wordCount = trimmed ? trimmed.split(/\\s+/).length : 0;\nconst path = wordCount > threshold ? 'decompose' : 'simple';\nconsole.log('[LengthGate] words=' + wordCount + ' threshold=' + threshold + ' path=' + path);\nreturn [{ json: { message, historyText: item.historyText || '', wordCount, threshold, path } }];"
