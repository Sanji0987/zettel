          "jsCode": "const item = $input.first().json;\nconst b = item.body || item;\nconst message = (b.message || '').toString();\nconst mode = b.mode === 'write' ? 'write' : 'read';\nconst history = Array.isArray(b.history) ? b.history : [];\nconst historyText = history.map(h => (h.role === 'assistant' ? 'Assistant: ' : 'User: ') + (h.content || '')).join('\\n');\nreturn [{ json: { message, mode, historyText } }];"
