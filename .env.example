# Cognee Cloud — Developer plan (REST API)
# Copy this file to .env and fill in your real key. NEVER commit .env.
COGNEE_BASE_URL=https://tenant-b24860eb-9dce-41a1-9f11-13d7a8f9cdd7.aws.cognee.ai
COGNEE_TENANT_ID=b24860eb-9dce-41a1-9f11-13d7a8f9cdd7
COGNEE_API_KEY=paste-your-rotated-key-here

# Ollama — the EXISTING container on the n8n-net Docker network (do not re-install).
# `docker start ollama` before use. Default matches the compose service env.
OLLAMA_BASE_URL=http://ollama:11434

# n8n chat webhook (the "brain"). Leave EMPTY to use the built-in mock reply so the
# chat UI works before n8n exists. Set to the real webhook URL to go live.
N8N_CHAT_WEBHOOK=
