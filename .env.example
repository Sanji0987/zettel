# Cognee Cloud — Developer plan (REST API)
# Copy this file to .env and fill in your real key. NEVER commit .env.
COGNEE_BASE_URL=https://tenant-b24860eb-9dce-41a1-9f11-13d7a8f9cdd7.aws.cognee.ai
COGNEE_TENANT_ID=b24860eb-9dce-41a1-9f11-13d7a8f9cdd7
COGNEE_API_KEY=paste-your-rotated-key-here

# Ollama — the EXISTING container on the n8n-net Docker network (do not re-install).
# `docker start ollama` before use. Default matches the compose service env.
OLLAMA_BASE_URL=http://ollama:11434

# n8n chat webhook (the "brain"). Leave EMPTY to use the built-in mock reply so the
# chat UI works before n8n exists. Set to the real webhook URL to go live.
N8N_CHAT_WEBHOOK=

# n8n write webhook (the "✎ Write note" flow: draft a note from the current chat, then
# refine it in a loop). Leave EMPTY for a built-in mock draft. Set to go live.
N8N_WRITE_WEBHOOK=

# Groq (cloud LLM for the n8n chat brain). The chat brain's model nodes now run
# Groq (openai/gpt-oss-120b) instead of local Ollama. The key is entered into the n8n
# "Groq account" credential (groqApi) in the n8n UI — the FastAPI app never uses it.
# Kept here for documentation / parity. Never commit the real key.
GROQ_API_KEY=paste-your-groq-key-here

# n8n sync worker webhook. The worker runs on a schedule inside n8n; this optional URL
# lets a manual "sync now" kick it immediately. Empty = manual kick disabled.
N8N_SYNC_WEBHOOK=

# Chunking: notes longer than this many words are split (paragraph/sentence boundaries)
# into multiple Cognee /add calls grouped under one node_set tag. Most notes are smaller
# and stay a single chunk.
CHUNK_WORD_THRESHOLD=800
